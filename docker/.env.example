# Copy to .env in this directory and fill in real values before running:
#   cd docker && docker compose --env-file .env up -d --build

# Public URLs — must match wherever your reverse proxy / DNS actually exposes
# these to the outside world. NEXT_PUBLIC_API_URL is baked into the web image
# at build time (Next.js inlines NEXT_PUBLIC_* vars), so the web image must be
# rebuilt whenever this changes.
WEB_ORIGIN=https://app.example.com
AUTH_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com

# Mongo — points at the standalone infra stack (docker-compose.infra.yml),
# wherever that's hosted. Credentials/host must match what you set there.
MONGO_URL=mongodb://<user>:<pass>@<infra-host>:27017/mongoops?replicaSet=rs0&authSource=admin

# Secrets — generate each with: openssl rand -hex 32
BETTER_AUTH_SECRET=
CLUSTER_SECRET_KEY=

# Default MinIO storage provider — auto-seeded as "Default MinIO" for any
# org that has no storage provider yet (see DEFAULT_STORAGE_* handling in
# apps/api/src/backup/storage-providers.service.ts). Point this at the
# MinIO from docker-compose.infra.yml; credentials must match its .env.
# Leave any of ENDPOINT/ACCESS_KEY_ID/SECRET_ACCESS_KEY blank to disable
# auto-seeding and add providers manually via the UI instead.
DEFAULT_STORAGE_ENDPOINT=http://<infra-host>:9000
DEFAULT_STORAGE_REGION=us-east-1
DEFAULT_STORAGE_BUCKET=mongoops-backups
DEFAULT_STORAGE_ACCESS_KEY_ID=
DEFAULT_STORAGE_SECRET_ACCESS_KEY=
DEFAULT_STORAGE_FORCE_PATH_STYLE=true
