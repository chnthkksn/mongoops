# Copy to .env in this directory and fill in real values before running:
#   cd docker && docker compose -f docker-compose.infra.yml --env-file .env up -d

# Mongo root credentials — required since --auth is enabled and the port
# is exposed to the internet. Generate with: openssl rand -hex 16
MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=

# The address external clients (your laptop, another VPS running the app)
# will use to reach Mongo — a public IP or domain, NOT the "mongo" service
# name. This gets written into the replica set config as the member's
# advertised host, and every client follows that address after its first
# connection (replica set discovery) — leaving this as "mongo" would let
# the initial handshake succeed but break every request after it for
# anyone outside this Docker network.
MONGO_EXTERNAL_HOST=

# MinIO credentials — used as the S3 access key / secret key from the app.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=mongoops-backups
