PORT=3001
MONGO_URL=mongodb://localhost:27017/mongoops
AUTH_BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
BETTER_AUTH_SECRET=changeme
CLUSTER_SECRET_KEY=changeme

# Optional: auto-seeds a "Default MinIO" storage provider for any org that
# has none yet, so it doesn't need to be added through the UI. No-op unless
# ENDPOINT/ACCESS_KEY_ID/SECRET_ACCESS_KEY are all set.
DEFAULT_STORAGE_ENDPOINT=
DEFAULT_STORAGE_REGION=us-east-1
DEFAULT_STORAGE_BUCKET=mongoops-backups
DEFAULT_STORAGE_ACCESS_KEY_ID=
DEFAULT_STORAGE_SECRET_ACCESS_KEY=
DEFAULT_STORAGE_FORCE_PATH_STYLE=true
